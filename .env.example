# Copy this file to .env and adjust values as needed.
# .env is gitignored and never committed.

# Port the server listens on
PORT=8080

# Upstream Broward County Transit API base URL
BCT_API=https://myride2.broward.org/TransitAPICore

# GCS bucket for persistent static cache (routes + stops).
# Leave unset for local dev — GCS is skipped when this is absent.
GCS_BUCKET=
